  <text>
    <front>
      <castList>
        <castItem>
          <role ana="#jupiter">Jupiter</role>
        </castItem>
        <castItem>
          <role ana="#mercure">Mercure</role>
        </castItem>
        <castItem>
          <role ana="#l_amour">L'Amour</role>
        </castItem>
        <castItem>
