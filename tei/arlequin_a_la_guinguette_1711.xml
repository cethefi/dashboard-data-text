  <text>
    <front>
      <prologue>
        <stage type="entrance"/>
        <stage type="entrance"/>
        <sp who="#arlequin">
          <l met="10">Charmant objet de ma pudique flamme</l>
          <l met="10">Je vais partir, recevez mes adieux,</l>
          <l met="4">Ma chère femme</l>
          <l met="4">Cédons aux Dieux.</l>
          <l met="10">Leurs dures lois m'arrachent de ces lieux</l>
          <l met="10">Un grand dessein appelle ma grande âme.</l>
        </sp>
        <sp who="#colombine">
          <l met="10">Qu'ai-je entendu? que j'éprouve d'alarmes!</l>
          <l met="10">Quoi? vous partez! Arlequin, vous partez!</l>
          <l met="4">Brillez mes charmes</l>
          <l met="4">Et l'arrêtez.</l>
          <l met="10">Mais tous mes cris ne sont plus écoutés:</l>
          <l met="10">Pleurez mes yeux, et fondez-vous en larmes!</l>
        </sp>
        <sp who="#colombine">
          <l met="8">Il part, et c'est pour m'outrager,</l>
          <l met="6">Je vois sa manigance,</l>
          <l met="7">Ne songeons qu'à nous venger</l>
          <l met="6">De ce trait d'inconstance;</l>
          <l met="8">Et dois-je attendre pour changer</l>
          <l met="6">Que mon mari commence?</l>
          <l met="8">Croit-il que pour lui seulement</l>
          <l met="6">Un tendre amour m'enflamme?</l>
          <l met="8">Je me sens pour faire un amant</l>
          <l met="6">Je ne sais quoi dans l'âme;</l>
          <l met="8">Si je n'aimais le changement</l>
          <l met="6">Je ne serais pas femme.</l>
        </sp>
        <sp who="#lelutin">
          <l met="8">S'il faut l'en croire sur sa foi</l>
          <l met="8">Colombine se meurt pour moi,</l>
          <l met="8">Mais parmi vous est-il de femme</l>
          <l met="8">Qui montre ce qu'elle a dans l'âme?</l>
          <l met="8">Telle pleure avec son mari</l>
          <l met="8">Qui rit avec son favori.</l>
        </sp>
        <sp who="#lelutin">
          <speaker>Le lutin</speaker>
          <l met="7">Je t'apporte ta toilette,</l>
          <l met="8">La Fée ainsi l'a commandé.</l>
          <l met="8">Si tu ne veux être grondé,</l>
          <l met="8">Fais ton devoir à la guinguette.</l>
          <l met="7">Je t'apporte ta toilette,</l>
          <l met="8">La Fée ainsi l'a commandé.</l>
        </sp>
        <sp who="#lepetitmaitre">
          <l met="8">Je fais l'amour la nuit entière,</l>
          <l met="8">J'ai des maîtresses à foison,</l>
          <l met="8">Je cours et change de maison,</l>
          <l met="6">Comme un chat de gouttière.</l>
        </sp>
        <sp who="#lesolliciteur">
          <l met="7">Il faut que je me débonde,</l>
          <l met="7">J'ai trop lieu d'être jaloux,</l>
          <l met="7">Est-ce ainsi qu'on me seconde?</l>
          <l met="7">J'ai cent fois quitté pour vous,</l>
          <l met="4">Et brune et blonde,</l>
          <l met="7">Et vous faites les yeux doux</l>
          <l met="4">À tout le monde.</l>
        </sp>
        <sp who="#lacoquette">
          <l met="7">Est-ce un mal pour la poulette</l>
          <l met="7">De compter sur plus d'un coq?</l>
          <l met="7">C'est un brin de ciboulette</l>
          <l met="7">Que la liberté du troc,</l>
          <l met="4">En amourette,</l>
          <l met="7">Ma foi, cela vous est hoc,</l>
          <l met="4">Je suis coquette.</l>
        </sp>
        <sp who="#arlequin">
          <l met="6">Les gens à procédure</l>
          <l met="6">Parfois sont amoureux,</l>
          <l met="6">Mais dans leurs aventures</l>
          <l met="6">Ils ne sont pas heureux.</l>
          <l met="6">Avec nos petits-maîtres,</l>
          <l met="6">S'ils osent s'oublier,</l>
          <l met="6">Ils sautent les fenêtres</l>
          <l met="7">Plutôt que les escaliers.</l>
        </sp>
        <stage type="musical_indication">Branle</stage>
        <sp who="#arlequin">
          <speaker>Arlequin</speaker>
          <l met="7">Aux guinguettes de Paris</l>
          <l met="7">Que de filles en voiture!</l>
          <l met="7">On y vend à juste prix</l>
          <l met="3">Turelure,</l>
          <l met="7">Bon vin et grande mesure</l>
          <l met="7">Robin turelurelure.</l>
          <l met="7">Jusqu'aux gens à cheveux gris,</l>
          <l met="7">Chacun y trouve aventure;</l>
          <l met="7">Sur la tête les maris</l>
          <l met="3">Turelure,</l>
          <l met="7">On y met mainte coiffure</l>
          <l met="7">Robin turelurelure.</l>
        </sp>
        <sp who="#lecapitan">
          <l met="5">Mets-nous, je te prie,</l>
          <l met="5">Dans un lieu secret,</l>
          <l met="5">Point de tricherie</l>
          <l met="5">N'entre dans mon fait,</l>
          <l met="5">Sans crime je l'aime</l>
          <l met="5">Et j'en suis chéri,</l>
          <l met="5">Laisse-nous à même</l>
          <l met="5">Je suis son mari.</l>
        </sp>
        <sp who="#arlequin">
          <l met="5">Ô le bon apôtre!</l>
          <l met="5">Ardez, quel époux!</l>
          <l met="5">Va chercher quelque autre</l>
          <l met="5">Pour tes rendez-vous;</l>
          <l met="5">Par ce beau langage</l>
          <l met="5">Tu n'as pris qu'un rat,</l>
          <l met="5">C'est un mariage</l>
          <l met="5">Qu'on fait sans contrat.</l>
        </sp>
        <sp who="#lecapitan">
          <l met="8">Serons-nous toujours sous tes yeux?</l>
          <l met="8">Le sot Argus! il est ma bête.</l>
          <l met="8">Crois-tu que l'on vienne en ces lieux</l>
          <l met="8">Pour ménager un tête-à-tête?</l>
          <l met="8">Il n'est plus rien grâce aux époux</l>
          <l met="8">De plus aisé qu'un rendez-vous.</l>
        </sp>
        <sp who="#arlequin">
          <l met="8">Je sais le trantran de Paris</l>
          <l met="8">Et rien n'en vient que je ne guette,</l>
          <l met="8">Pour mettre l'honneur des maris</l>
          <l met="8">En sûreté dans ma guinguette,</l>
          <l met="8">S'ils avaient tous de ces Argus</l>
          <l met="8">On verrait bien moins de cocus.</l>
        </sp>
        <sp who="#ledocteur">
          <l met="8">Ma maîtresse se fait attendre...</l>
          <l met="8">Mais l'hôte vient, je l'aperçois:</l>
          <l met="8">Un ami doit ici se rendre</l>
          <l met="8">Il n'a pu partir qu'après moi;</l>
          <l met="8">Si la nuit vient à nous surprendre</l>
          <l met="8">Trouverons-nous un lit chez toi?</l>
        </sp>
        <sp who="#arlequin">
          <speaker>arlequin</speaker>
          <stage>répond sur l'air<emph>De mon pot, je vous en réponds</emph>
          </stage>
          <l met="7">Une chambre à deux amis</l>
          <l met="6">Cela vous est promis,</l>
          <l met="8">Mais si c'est un ami femelle</l>
          <l met="8">Allez au moulin de Javelle:</l>
          <l met="8">Pour l'ami je vous en réponds,</l>
          <l met="6">Pour la femelle, non.</l>
        </sp>
        <sp who="#lelutin">
          <l met="10">Console-toi, malheureux Arlequin,</l>
          <l met="12">De porter sur ton front les armes de Vulcain,</l>
          <l met="8">Ta disgrâce n'est que trop sûre,</l>
          <l met="3">Mais j'en vois</l>
          <l met="10">Qui trouvant une pareille aventure</l>
          <l met="7">Ne font tant de bruit que toi.</l>
        </sp>
        <sp who="#arlequin">
          <l met="10">J'avais prié Pierrot et Scaramouche,</l>
          <l met="10">Mais pour souper en vain je les attends,</l>
          <l met="10">Ils n'auront pas de quoi rincer leur bouche,</l>
          <l met="10">Ils n'auront rien à mettre sous leurs dents.</l>
        </sp>
        <stage type="entrance"/>
        <sp who="#arlequin">
          <speaker>arlequin</speaker>
          <p>[...]</p>
        </sp>
        <stage>Fin</stage>
      </prologue>
    </front>
