    <front>
      <castList>
        <castItem>
          <role ana="#la_veuve">La Veuve</role>
        </castItem>
        <castItem>
          <role ana="#olivette">Olivette</role>
          <roleDesc>sa suivante</roleDesc>
        </castItem>
        <castItem>
          <role ana="#blaise">Blaise</role>
          <roleDesc>jardinier de la veuve</roleDesc>
        </castItem>
        <castItem>
          <role ana="#arlequin">Arlequin</role>
          <roleDesc>laquais</roleDesc>
        </castItem>
        <castItem>
          <role ana="#scaramouche">Scaramouche</role>
          <roleDesc>laquais</roleDesc>
        </castItem>
        <castItem>
          <role ana="#damis">Damis</role>
          <roleDesc>courtisan de la veuve</roleDesc>
        </castItem>
        <castItem>
          <role ana="#un_procureur">Un procureur</role>
          <roleDesc>courtisan de la veuve<note>Ms. 2: une«troupe de pêcheur»est ajoutée à la liste des personnages.</note>
          </roleDesc>
        </castItem>
      </castList>
      <prologue>
        <spGrp rend="trpta">
          <sp who="#scaramouche">
            <speaker>Scaramouche</speaker>
          </sp>
        </spGrp>
        <stage type="location">La scène est à Charenton, sur le bord de la rivière.</stage>
        <stage type="location">Le théâtre représente une rivière dans le fond et une maison de campagne dans l'une des ailes.</stage>
      </prologue>
    </front>
    <body>
      <div type="scene">
        <head>SCENE 1</head>
        <stage type="characters">Arlequin, Scaramouche</stage>
        <spGrp who="#scaramouche">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#un_sot_qui_veut_faire_l_habile">Un sot qui veut faire l'habile</title>
            </desc>
          </head>
          <sp who="#scaramouche">
            <speaker>Scaramouche</speaker>
            <l met="8">Cher Arlequin, ce beau rivage</l>
            <l met="10">Offre à nos yeux les bains de Charenton.</l>
            <l met="8">Vite, jetons-nous à la nage<note>Ms. 2: vers absent.</note>!</l>
          </sp>
        </spGrp>
        <sp who="#arlequin">
          <speaker>Arlequin</speaker>
          <stage>tenant une bouteille</stage>
          <l met="10">Nous ferons mieux de vider ce flacon.</l>
          <l met="10">En se baignant c'est chercher, camarade,</l>
          <l met="6">À devenir malade</l>
          <l met="5">Car les médecins</l>
          <l met="7">Disent qu'à présent les bains<note>Note dans la marge: «<emph>Les Bains de Charenton</emph>, pièce de l'Opéra-Comique, n'avaient pas été trouvés bons ».</note>
          </l>
          <l met="5">Ne sont pas trop sains.</l>
        </sp>
        <sp who="#scaramouche">
          <speaker>Scaramouche</speaker>
          <stage>
            <note>Ms. 2: «<emph>Scaramouche, après avoir applaudi du geste</emph>».</note>
          </stage>
        </sp>
        <spGrp who="#scaramouche">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#vivons_pour_ces_fillettes">Vivons pour ces fillettes</title>
            </desc>
          </head>
          <sp who="#scaramouche">
            <speaker>Scaramouche</speaker>
            <l met="8">La rivière est pour les poissons.<stage>bis</stage>
            </l>
            <l met="8">Mais l'élément des bons garçons</l>
            <l met="6">Est le jus de la treille.</l>
          </sp>
        </spGrp>
        <sp who="#tousdeux">
          <speaker>Tous deux</speaker>
          <l met="6">Vivons pour la bouteille,</l>
          <l met="2">Vivons,</l>
          <l met="6">Vivons pour la bouteille!</l>
        </sp>
      </div>
      <div type="scene">
        <head>SCENE 2</head>
        <stage type="characters">Arlequin, Scaramouche, Olivette</stage>
        <sp who="#olivette">
          <speaker>Olivette</speaker>
          <stage>
            <note>Ms. 2: «<emph>Olivette, en colère</emph>».</note>
          </stage>
        </sp>
        <spGrp who="#olivette">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#aimant_colette">Tu croyais en aimant [Colette]</title>
            </desc>
          </head>
          <sp who="#olivette">
            <speaker>Olivette</speaker>
            <l met="8">Allez-vous en, messieurs, de grâce,</l>
            <l met="8">Faire plus loin les polissons</l>
            <l met="8">Ou chantez d'une voix plus basse</l>
            <l met="8">Vos impertinentes chansons.</l>
          </sp>
        </spGrp>
        <sp who="#arlequin">
          <speaker>Arlequin</speaker>
        </sp>
        <spGrp who="#arlequin">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#et_zon_zon_zon">Zon zon zon</title>
            </desc>
          </head>
          <sp who="#arlequin">
            <speaker>Arlequin</speaker>
            <l met="6">On voit bien à vos yeux,</l>
            <l met="6">Ma petite brunette,</l>
            <l met="6">Que vous aimeriez mieux</l>
            <l met="6">Une autre chansonnette.</l>
            <l met="4">Et zon, zon, zon,</l>
            <l met="6">Je vous vais sur l'herbette,</l>
            <l met="4">Et zon, zon, zon,</l>
            <l met="6">Chanter un mirliton<note type="definition">Mirliton: Refrain populaire (Littré)</note>.</l>
          </sp>
        </spGrp>
        <sp who="#olivette">
          <speaker>Olivette</speaker>
        </sp>
        <spGrp who="#olivette">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#berger_tircis">Le beau berger Tircis</title>
            </desc>
          </head>
          <sp who="#olivette">
            <speaker>Olivette</speaker>
            <l met="6">Ne parlons point d'amour.</l>
          </sp>
        </spGrp>
        <sp who="#arlequin">
          <speaker>Arlequin</speaker>
          <l met="6">Hé, d'où vient, ma princesse?</l>
        </sp>
        <sp who="#olivette">
          <speaker>Olivette</speaker>
          <l met="7">De cet aimable séjour,</l>
          <l met="7">On a banni la tendresse.</l>
          <l met="6">Une affreuse tristesse</l>
          <l met="6">Y règne nuit et jour.</l>
        </sp>
        <stage>Arlequin et Scaramouche lui demandent par gestes ce qu'elle veut dire.</stage>
        <sp who="#olivette">
          <speaker>Olivette</speaker>
        </sp>
        <spGrp who="#olivette">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air du</desc>
            <desc type="title">
              <title ref="#cap_de_bonne_esperance">Cap de Bonne Espérance</title>
            </desc>
          </head>
          <sp who="#olivette">
            <speaker>Olivette</speaker>
            <l met="7">Je sers une jeune brune,</l>
            <l met="7">Veuve depuis quinze mois</l>
            <l met="7">D'un quidam<note type="definition">Quidam: Terme emprunté du latin et dont on se sert dans les monitoires, procès verbaux, informations, etc.  pour désigner les personnes dont on ignore ou dont on n'exprime point le nom (Acad.1762)</note>qui fit fortune</l>
            <l met="7">Dans le quartier Quincampoix.</l>
            <l met="7">Loin des plaisirs de la ville,</l>
            <l met="7">En secret, dans cet asile,</l>
            <l met="7">Elle pleure incessamment</l>
            <l met="7">Son mari comme un amant.</l>
          </sp>
        </spGrp>
        <spGrp who="#olivette">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#ici_chacun">Malheureuse journée<note>Ms. 2: air situé après la didascalie suivante: «<emph>Arlequin et Scaramouche font leurs étonnements</emph>».</note>
              </title>
            </desc>
          </head>
          <sp who="#olivette">
            <speaker>Olivette</speaker>
            <l met="6">Toujours abandonnée</l>
            <l met="6">À ses vives douleurs,</l>
            <l met="6">Vingt fois dans la journée</l>
            <l met="6">Il lui prend des vapeurs.</l>
            <l met="6">Il faut veiller sur elle</l>
            <l met="6">Tant les jours que les nuits,</l>
            <l met="6">Cacher couteaux, ficelle,</l>
            <l met="6">Et boucher tous les puits.</l>
          </sp>
        </spGrp>
        <stage>Arlequin et Scaramouche font de grands étonnements de surprise.</stage>
        <spGrp who="#olivette">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#tique_tique">Tique tique</title>
            </desc>
          </head>
          <sp who="#olivette">
            <speaker>Olivette</speaker>
            <l met="7">L'autre jour, dans un transport,</l>
            <l met="7">Voulant se donner la mort,</l>
            <l met="7">D'un grand couteau de cuisine,</l>
            <l met="9">Tique, tique, taque et lonlanla,</l>
            <l met="7">Elle eût percé sa poitrine</l>
            <l met="7">Si je n'avais été là.</l>
          </sp>
        </spGrp>
        <sp who="#scaramouche">
          <speaker>Scaramouche</speaker>
        </sp>
        <spGrp who="#scaramouche">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air du</desc>
            <desc type="title">
              <title ref="#peril_agreable">Péril<note>Ms. 2: « Quand le péril ».</note>
              </title>
            </desc>
          </head>
          <sp who="#scaramouche">
            <speaker>Scaramouche</speaker>
            <l met="8">Vous nous contez une merveille</l>
            <l met="8">Dont chacun doit être surpris.</l>
          </sp>
        </spGrp>
        <sp who="#arlequin">
          <speaker>Arlequin</speaker>
          <l met="8">Peut-on voir, si près de Paris,</l>
          <l met="6">Une veuve pareille?</l>
        </sp>
        <sp who="#scaramouche">
          <speaker>Scaramouche</speaker>
        </sp>
        <spGrp who="#scaramouche">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#un_clou_chasse_l_autre">Un clou chasse l'autre</title>
            </desc>
          </head>
          <sp who="#scaramouche">
            <speaker>Scaramouche</speaker>
            <l met="7">Mais, ma mignonne, entre nous,</l>
            <l met="7">Que ne lui conseillez-vous,</l>
            <l met="6">Pour son bien et le vôtre,</l>
            <l met="7">De prendre un nouvel époux?</l>
            <l met="6">Car un clou chasse l'autre<note type="definition">Un clou chasse l'autre: On dit proverbialement et figurément qu'un clou chasse l'autre, pour dire, qu'une nouvelle passion en chasse une autre. (Acad.1694)</note>!</l>
          </sp>
        </spGrp>
        <sp who="#olivette">
          <speaker>Olivette</speaker>
        </sp>
        <spGrp who="#olivette">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#lere_lan_laire">Lere lan laire</title>
            </desc>
          </head>
          <sp who="#olivette">
            <speaker>Olivette</speaker>
            <l met="8">Elle a vu brunets et blondins,</l>
            <l met="8">Négociants, plumets<note type="definition">Plumet: Se dit d'un jeune homme qui porte un plumet, et ordinairement il ne se dit en ce sens que par raillerie ou par mépris (Acad.1762)</note>, robins<note type="definition">Robin: Terme de mépris dont on se sert en parlant des gens de robe. Il est familier (Acad.1762)</note>,</l>
            <l met="8">Aucun galant ne peut lui plaire.</l>
          </sp>
        </spGrp>
        <sp who="#arlequinetscaramouche">
          <speaker>Arlequin et Scaramouche</speaker>
          <l met="4">Lerelanlere, etc.<note>Développé sur ms. 2: « Laire la, laire, lanlaire, / Laire la, / Laire lan la ».</note>
          </l>
        </sp>
        <sp who="#arlequin">
          <speaker>Arlequin</speaker>
        </sp>
        <spGrp who="#arlequin">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#y_avance_y_avance">Y avance</title>
            </desc>
          </head>
          <sp who="#arlequin">
            <speaker>Arlequin</speaker>
            <l met="8">Moi, si je lui parlais d'amour,</l>
            <l met="8">Je gage, avec mes airs de cour,</l>
            <l met="8">De mettre à cul<note type="definition">Mettre à cul: Arrêter net (Acad.1798)</note>sa résistance.</l>
          </sp>
        </spGrp>
        <sp who="#olivette">
          <speaker>Olivette</speaker>
          <stage>se moquant</stage>
          <l met="9">Y avance, y avance, y avance,</l>
          <l met="8">Avec ton habit d'ordonnance<note type="definition">Habit d'ordonnance: Habillement uniforme que les officiers et les soldats doivent avoir dans chaque régiment, ou dans une certaine compagnie du régiment (Acad.1762)</note>.</l>
        </sp>
        <sp who="#arlequin">
          <speaker>Arlequin</speaker>
        </sp>
        <spGrp who="#arlequin">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#la_jeune_abbesse">La jeune abbesse</title>
            </desc>
          </head>
          <sp who="#arlequin">
            <speaker>Arlequin</speaker>
            <l met="8">Mon enfant, l'habit n'y fait rien,</l>
            <l met="8">Mets-moi seulement à l'épreuve.</l>
            <l met="8">Fais-moi, tu t'en trouveras bien,</l>
            <l met="8">Épouser cette riche veuve.</l>
          </sp>
        </spGrp>
        <sp who="#olivette">
          <speaker>Olivette</speaker>
          <l met="9">Volontiers. Aussi bien son époux</l>
          <l met="8">Était du même bois que vous.</l>
        </sp>
        <spGrp who="#olivette">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#si_dans_le_mal_qui_me_possede">Si dans le mal qui me possède</title>
            </desc>
          </head>
          <sp who="#olivette">
            <speaker>Olivette</speaker>
            <l met="8">La dame va, sur ce rivage,</l>
            <l met="8">De la pêche dans un moment</l>
            <l met="8">Prendre le divertissement.</l>
            <l met="8">Vite, allez changer d'équipage,</l>
            <l met="8">Venez vous offrir à ses yeux,</l>
            <l met="8">Parlez, faites de votre mieux.</l>
          </sp>
        </spGrp>
        <sp who="#arlequin">
          <speaker>Arlequin</speaker>
        </sp>
        <spGrp who="#arlequin">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#coucou">Comme un coucou [que l'amour presse]</title>
            </desc>
          </head>
          <sp who="#arlequin">
            <speaker>Arlequin</speaker>
            <l met="8">Mais attendez...</l>
          </sp>
        </spGrp>
        <sp who="#olivette">
          <speaker>Olivette</speaker>
          <l met="8">Qui vous arrête?</l>
        </sp>
        <sp who="#arlequin">
          <speaker>Arlequin</speaker>
          <l met="8">J'enfante un des plus beaux projets...</l>
          <l met="8">Prêtez-nous la main et la bête</l>
          <l met="8">Sera bientôt dans nos filets.</l>
        </sp>
        <stage>On voit par ses gestes qu'il communique son dessein à Olivette et à Scaramouche, qui l'approuvent. Arlequin et Scaramouche se retirent.</stage>
      </div>
      <div type="scene">
        <head>SCENE 3</head>
        <stage type="characters">Olivette<stage>seule</stage>
        </stage>
        <spGrp who="#arlequin">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#capucin">Je ne suis né ni roi, ni [prince]</title>
            </desc>
          </head>
          <sp who="#arlequin">
            <speaker>Arlequin</speaker>
            <l met="8">Ah, que ma vie est ennuyeuse</l>
            <l met="8">De voir toujours une pleureuse</l>
            <l met="8">Et n'entendre que des « hélas »,</l>
            <l met="8">De m'affliger par complaisance!</l>
            <l met="8">Sans mon Blaise, je n'aurais pas</l>
            <l met="8">Jusqu'à ce jour pris patience.</l>
          </sp>
        </spGrp>
      </div>
      <div type="scene">
        <head>SCENE 4</head>
        <stage type="characters">Olivette, Blaise</stage>
        <sp who="#blaise">
          <speaker>Blaise</speaker>
        </sp>
        <spGrp who="#blaise">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#blaise_en_revenant">Blaise en revenant</title>
            </desc>
          </head>
          <sp who="#blaise">
            <speaker>Blaise</speaker>
            <l met="7">Morgué, queux charivari<note>
                <emph>Charivari</emph>: toute sorte de bruit qu'on faisait pour un mariage mal assorti.</note>
            </l>
            <l met="4">Pour un mari!<stage>bis</stage>
            </l>
          </sp>
        </spGrp>
        <sp who="#olivette">
          <speaker>Olivette</speaker>
          <l met="7">Je vais, mon cher favori,</l>
          <l met="5">Mon fidèle Blaise,</l>
          <l met="5">Te faire bien aise.</l>
        </sp>
        <stage>Elle lui dit à l'oreille le tour qu'Arlequin veut faire à la veuve.</stage>
        <sp who="#blaise">
          <speaker>Blaise</speaker>
        </sp>
        <spGrp who="#blaise">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#mirlababibobette">Mirlababibobette</title>
            </desc>
          </head>
          <sp who="#blaise">
            <speaker>Blaise</speaker>
            <l met="8">Tatigué, si ce garçon-là,</l>
            <l met="6">Mirlababibobette,</l>
            <l met="3">Fait cela,</l>
            <l met="8">Biantôt Blaise avec Olivette,</l>
            <l met="13">Miralababi, serlababo, mirlababibobette,</l>
            <l met="6">Serlababorita,</l>
            <l met="4">Se mariera.</l>
          </sp>
        </spGrp>
      </div>
      <div type="scene">
        <head>SCENE 5</head>
        <stage type="characters">Olivette, Blaise, La veuve, Damis</stage>
        <sp who="#damis">
          <speaker>Damis</speaker>
        </sp>
        <spGrp who="#damis">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#belle_brune">Belle brune</title>
            </desc>
          </head>
          <sp who="#damis">
            <speaker>Damis</speaker>
            <l met="3">Inhumaine,</l>
            <l met="3">Inhumaine!</l>
          </sp>
        </spGrp>
        <sp who="#veuve">
          <speaker>La Veuve</speaker>
          <l met="7">Oui, plus je vous vois, Damis,</l>
          <l met="7">Plus je prends pour vous de haine.</l>
        </sp>
        <sp who="#damis">
          <speaker>Damis</speaker>
          <stage>s'en allant</stage>
          <l met="3">Inhumaine!<stage>bis</stage>
          </l>
        </sp>
      </div>
      <div type="scene">
        <head>SCENE 6</head>
        <stage type="characters">Olivette, Blaise, un procureur, la veuve</stage>
        <sp who="#procureur">
          <speaker>Le procureur</speaker>
        </sp>
        <spGrp who="#procureur">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#l_amour_me_fait_lon_lan_la">L'Amour me fait [mourir]<note>Ms. 2: « L'amour me fait mourir ».</note>
              </title>
            </desc>
          </head>
          <sp who="#procureur">
            <speaker>Le procureur</speaker>
            <l met="6">Écoutez la requête</l>
            <l met="7">Que l'Amour vient vous offrir.</l>
          </sp>
        </spGrp>
        <sp who="#veuve">
          <speaker>La Veuve</speaker>
          <l met="6">Vous me rompez la tête.</l>
        </sp>
        <sp who="#procureur">
          <speaker>Le procureur</speaker>
          <l met="6">Daignez me secourir,</l>
          <l met="7">L'Amour me fait, lonlanla,</l>
          <l met="6">L'Amour me fait mourir.</l>
        </sp>
        <sp who="#veuve">
          <speaker>La Veuve</speaker>
        </sp>
        <spGrp who="#veuve">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#jean_gille">[Jean Gille]</title>
            </desc>
          </head>
          <sp who="#veuve">
            <speaker>La Veuve</speaker>
            <l met="7">Votre peine est inutile,</l>
            <l met="2">Jean Gille,</l>
            <l met="5">Gille, joli Jean.</l>
          </sp>
        </spGrp>
        <sp who="#olivette">
          <speaker>Olivette</speaker>
          <l met="7">Allez gruger<note type="definition">Gruger: Manger le bien de quelqu'un (Acad.1762)</note>le pupille,</l>
          <l met="2">Jean Gille,</l>
          <l met="11">Gille joli Gille, Gille joli Jean,</l>
          <l met="5">Joli Jean, Jean Gille,</l>
          <l met="5">Retournez-vous en.</l>
        </sp>
      </div>
      <div type="scene">
        <head>SCENE 7</head>
        <stage type="characters">Olivette, La veuve</stage>
        <spGrp who="#olivette">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#vous_brillez_seule">Vous brillez seule</title>
            </desc>
          </head>
          <sp who="#olivette">
            <speaker>Olivette</speaker>
            <l met="8">Hélas, ce n'est pas là, ma chère,</l>
            <l met="10">Ce tendre époux qui fait couler mes pleurs!</l>
          </sp>
        </spGrp>
        <sp who="#olivette">
          <speaker>Olivette</speaker>
          <l met="8">Il faut chercher à vous distraire.</l>
        </sp>
        <sp who="#veuve">
          <speaker>La Veuve</speaker>
          <l met="11">Je languis, je languis!</l>
        </sp>
        <sp who="#olivette">
          <speaker>Olivette</speaker>
          <l met="11">Voici les pêcheurs.</l>
        </sp>
        <stage>On entend en cet endroit un grand bruit confus de voix<note>Ms. 2: «<emph>[...] et Blaise arrive tout essoufflé</emph>».</note>.</stage>
      </div>
      <div type="scene">
        <head>SCENE 8</head>
        <stage type="characters">La veuve, Olivette, Blaise</stage>
        <sp who="#blaise">
          <speaker>Blaise</speaker>
        </sp>
        <spGrp who="#blaise">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#que_faites_vous_marguerite">Que faites-vous Marguerite</title>
            </desc>
          </head>
          <sp who="#blaise">
            <speaker>Blaise</speaker>
            <l met="7">Quel malheur!</l>
          </sp>
        </spGrp>
        <sp who="#veuve">
          <speaker>La Veuve</speaker>
          <l met="4">Qu'est-ce donc, Blaise?</l>
        </sp>
        <sp who="#blaise">
          <speaker>Blaise</speaker>
          <l met="7">Les pêcheurs, dans leur filet,</l>
          <l met="7">Ont trouvé (ne vous déplaise)</l>
          <l met="7">Un jeune homme assez bien fait.</l>
        </sp>
      </div>
      <div type="scene">
        <head>SCENE 9</head>
        <stage type="characters">La Veuve, Olivette, Blaise, Arlequin, pêcheurs</stage>
        <stage>Les pêcheurs amènent Arlequin dans leur filet. Il est vêtu de noir et a des pleureuses. On le retire du filet et les pêcheurs font le lazzi de lui faire rendre l'eau qu'ils veulent faire croire qu'il a avalée<note>Ms. 2: «<emph>[...] qu'ils font croire qu'il a avalée</emph>».</note>.</stage>
        <sp who="#blaise">
          <speaker>Blaise</speaker>
        </sp>
        <spGrp who="#blaise">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air des</desc>
            <desc type="title">
              <title ref="#trembleurs">Trembleurs</title>
            </desc>
          </head>
          <sp who="#blaise">
            <speaker>Blaise</speaker>
            <l met="7">Monsieur le noyé, courage!</l>
          </sp>
        </spGrp>
        <sp who="#olivette">
          <speaker>Olivette</speaker>
          <l met="7">Ma foi, ce serait dommage</l>
          <l met="7">Que ce brunet, à son âge,</l>
          <l met="7">Descendît dans le tombeau.</l>
        </sp>
        <sp who="#arlequin">
          <speaker>Arlequin</speaker>
          <stage>se débattant</stage>
          <l met="7">Ah, que je suis misérable!</l>
        </sp>
        <sp who="#blaise">
          <speaker>Blaise</speaker>
          <l met="7">Comme il se débat! Que diable,</l>
          <l met="7">Devenez donc raisonnable!</l>
          <l met="7">N'avous pas assez bu d'iau?</l>
        </sp>
        <sp who="#veuve">
          <speaker>La Veuve</speaker>
        </sp>
        <spGrp who="#veuve">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air d'</desc>
            <desc type="title">
              <title ref="#octobre">Octobre<note>Ms. 2: « Quand je tiens de ce jus ».</note>
              </title>
            </desc>
          </head>
          <sp who="#veuve">
            <speaker>La Veuve</speaker>
            <l met="8">Prêtez-vous au soin favorable</l>
            <l met="8">Que nous prenons de vous sauver.</l>
          </sp>
        </spGrp>
        <sp who="#olivette">
          <speaker>Olivette</speaker>
          <l met="8">Regardez l'objet adorable</l>
          <l met="8">Qui s'empresse à vous<note>Ms: « avous ».</note>conserver.</l>
        </sp>
        <sp who="#arlequin">
          <speaker>Arlequin</speaker>
        </sp>
        <spGrp who="#arlequin">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air des</desc>
            <desc type="title">
              <title ref="#pelerins">Pèlerins</title>
            </desc>
          </head>
          <sp who="#arlequin">
            <speaker>Arlequin</speaker>
            <l met="8">Vouloir me rendre à la lumière,</l>
            <l met="4">C'est cruauté.</l>
            <l met="8">Rejetez-moi dans la rivière</l>
            <l met="4">Par charité.</l>
            <l met="8">Plutôt que de souffrir les maux</l>
            <l met="4">Qu'ici j'endure,</l>
            <l met="8">J'aime mieux cent fois, des barbeaux,<note type="definition">Barbeau: Poisson d'eau douce, ainsi nommé parce qu'il a comme quatre barbes, ou moustaches, deux à côté de chaque mâchoire (Acad.1762)</note>
            </l>
            <l met="6">Devenir la pâture.</l>
          </sp>
        </spGrp>
        <sp who="#veuve">
          <speaker>La Veuve</speaker>
        </sp>
        <spGrp who="#veuve">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#moment_plus_tard">Je suis perdue</title>
            </desc>
          </head>
          <sp who="#veuve">
            <speaker>La Veuve</speaker>
            <l met="8">Hé, pourquoi donc souhaitez-vous</l>
            <l met="5">Ce sort déplorable?</l>
          </sp>
        </spGrp>
        <sp who="#arlequin">
          <speaker>Arlequin</speaker>
          <l met="8">Je suis le malheureux époux</l>
          <l met="5">D'une dame aimable.</l>
          <l met="7">C'était de mille vertus</l>
          <l met="6">Une femme pourvue,</l>
          <l met="7">Mais, hélas, n'en parlons plus,</l>
          <l met="6">Elle est, elle est perdue!</l>
        </sp>
        <sp who="#veuve">
          <speaker>La Veuve</speaker>
        </sp>
        <spGrp who="#veuve">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#les_filles_de_nanterre">Les filles de Nanterre<note>Ms. 2: indication d'air absente.</note>
              </title>
            </desc>
          </head>
          <sp who="#veuve">
            <speaker>La Veuve</speaker>
            <l met="6">Pour ne lui pas survivre,</l>
            <l met="6">Vous vouliez donc périr?</l>
          </sp>
        </spGrp>
        <sp who="#arlequin">
          <speaker>Arlequin</speaker>
          <l met="6">Oui, je prétends la suivre.</l>
          <l met="6">Qu'on me laisse mourir.</l>
        </sp>
        <sp who="#veuve">
          <speaker>La Veuve</speaker>
        </sp>
        <spGrp who="#veuve">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#dans_nos_forets">On n'aime point [dans nos forêts]<note>Ms. 2: « On n'aime point dans nos forêts ».</note>
              </title>
            </desc>
          </head>
          <sp who="#veuve">
            <speaker>La Veuve</speaker>
            <l met="8">Je suis sensible autant que vous.</l>
            <l met="8">Au chagrin, j'ai livré mon âme,</l>
            <l met="8">La mort m'a ravi mon époux,</l>
            <l met="8">Vous avez perdu votre femme.</l>
            <l met="8">Au lieu de nous désespérer,</l>
            <l met="8">Contentons-nous de les pleurer<note>Sur le Ms. 2, le même vaudeville est repris par Arlequin, avec les mêmes paroles. Il semble s'agir d'une erreur.</note>.</l>
          </sp>
        </spGrp>
        <sp who="#arlequin">
          <speaker>Arlequin</speaker>
        </sp>
        <spGrp who="#arlequin">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#beaux_yeux_nicole">Tes beaux yeux ma Nicole</title>
            </desc>
          </head>
          <sp who="#arlequin">
            <speaker>Arlequin</speaker>
            <l met="6">Tout à coup de la vie</l>
            <l met="6">Renaît en moi l'amour.</l>
            <l met="6">Je ne sens plus d'envie</l>
            <l met="6">De renoncer au jour.</l>
            <l met="6">La bonté de Madame,</l>
            <l met="6">Par un charme secret,</l>
            <l met="6">De la mort de ma femme</l>
            <l met="6">Adoucit le regret.</l>
          </sp>
        </spGrp>
        <stage>La veuve s'attendrit et pousse quelques soupirs.</stage>
        <sp who="#arlequin">
          <speaker>Arlequin</speaker>
        </sp>
        <spGrp who="#arlequin">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#l_autre_jour_ma_cloris">L'autre jour ma Cloris</title>
            </desc>
          </head>
          <sp who="#arlequin">
            <speaker>Arlequin</speaker>
            <l met="6">Comme dans un miroir,</l>
            <l met="6">Quand je vous considère,</l>
            <l met="6">Je m'imagine voir</l>
            <l met="6">Ma pauvre ménagère.</l>
          </sp>
        </spGrp>
        <sp who="#veuve">
          <speaker>La Veuve</speaker>
          <l met="6">Et moi, je vois en vous</l>
          <l met="6">Les traits de mon époux.</l>
        </sp>
        <sp who="#arlequin">
          <speaker>Arlequin</speaker>
        </sp>
        <spGrp who="#arlequin">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#mariez_mariez_moi">Mariez, mariez, [mariez-moi]<note>Ms. 2: « Mariez, mariez, mariez-moi ».</note>
              </title>
            </desc>
          </head>
          <sp who="#arlequin">
            <speaker>Arlequin</speaker>
            <l met="7">Ô, succulente beauté,</l>
            <l met="7">Quel bonheur serait le nôtre</l>
            <l met="7">Si<note>Le scripteur, sur le Ms. 2, n'a pas continué la transcription de l'air, et s'arrête au « si ».</note>vous aviez la bonté</l>
            <l met="7">De joindre mon sort au vôtre!</l>
          </sp>
        </spGrp>
        <sp who="#olivette">
          <speaker>Olivette</speaker>
          <l met="10">Mariez, mariez, mariez-vous,</l>
          <l met="7">Vous êtes faits l'un pour l'autre.</l>
          <l met="10">Mariez, mariez, mariez-vous,</l>
          <l met="7">Ramenez les ris chez nous.</l>
        </sp>
        <sp who="#veuve">
          <speaker>La Veuve</speaker>
        </sp>
        <spGrp who="#veuve">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#nya_pas_dmal">N'y a pas de mal à ça</title>
            </desc>
          </head>
          <sp who="#veuve">
            <speaker>La Veuve</speaker>
            <l met="5">Mon cœur s'intéresse</l>
            <l met="5">Pour ce brunet-là,</l>
            <l met="5">Mais de ma faiblesse,</l>
            <l met="5">Qu'est-ce qu'on dira?</l>
          </sp>
        </spGrp>
        <sp who="#olivette">
          <speaker>Olivette</speaker>
          <l met="7">N'y a pas de mal à ça<note>Ms. 2: vers répété deux fois.</note>.</l>
        </sp>
        <stage>Elle leur fait prendre la main à l'un et à l'autre. Lazzis de la veuve et d'Arlequin<note>Ms. 2: le divertissement qui suit est nommé « branle ».</note>.</stage>
        <spGrp who="#olivette">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#suivons_tour_a_tour">Suivons, suivons tour à tour</title>
            </desc>
          </head>
        </spGrp>
        <spGrp>
          <head type="vaudeville-chorus">0</head>
          <sp who="#olivette">
            <speaker>Olivette</speaker>
            <l met="7">Lorsqu'à sa douleur mortelle</l>
            <l met="7">La veuve se laisse aller,</l>
            <l met="7">Amants, pleurez avec elle,</l>
            <l met="7">Vous pourrez la consoler.</l>
            <l met="7">C'est avec cet hameçon</l>
            <l met="5">Qu'on prend ce poisson.</l>
          </sp>
        </spGrp>
        <sp who="#choeurb">
          <speaker>Chœur</speaker>
          <l met="7">C'est avec cet hameçon</l>
          <l met="5">Qu'on prend ce poisson.</l>
        </sp>
        <spGrp>
          <head type="vaudeville-chorus">1</head>
          <sp who="#pecheur">
            <speaker>Un pêcheur</speaker>
            <l met="7">Un vieillard encor bon drille<note type="definition">Drille: On dit familièrement c'est un bon drille pour dire c'est un bon compagnon (Acad.1762)</note>
            </l>
            <l met="7">Rend en beaux deniers comptant</l>
            <l met="7">Tout ce que perd au quadrille<note type="definition">Quadrille: Espèce de jeu d'hombre qui se joue à quatre (Littré)</note>
            </l>
            <l met="7">Une dame de vingt ans.</l>
            <l met="7">C'est avec cet hameçon</l>
            <l met="5">Qu'on prend ce poisson.</l>
          </sp>
        </spGrp>
        <sp who="#choeurb">
          <speaker>Chœur</speaker>
          <l met="7">C'est avec cet hameçon</l>
          <l met="5">Qu'on prend ce poisson.</l>
        </sp>
        <spGrp>
          <head type="vaudeville-chorus">2</head>
          <sp who="#unautrepecheur">
            <speaker>Un autre pêcheur</speaker>
            <l met="7">Aujourd'hui bonne cuisine</l>
            <l met="7">Sert un amoureux dessein.</l>
            <l met="7">Pour l'amour de sa voisine,</l>
            <l met="7">On régale son voisin.</l>
            <l met="7">C'est avec cet hameçon</l>
            <l met="5">Qu'on prend ce poisson.</l>
          </sp>
        </spGrp>
        <sp who="#choeurb">
          <speaker>Chœur</speaker>
          <l met="7">C'est avec cet hameçon</l>
          <l met="5">Qu'on prend ce poisson.</l>
        </sp>
        <stage>Au parterre.</stage>
        <sp who="#arlequin">
          <speaker>Arlequin</speaker>
          <l met="7">Une pièce surannée</l>
          <l met="7">Pendant un mois se soutient.</l>
          <l met="7">On l'avait abandonnée,</l>
          <l met="7">On y retourne. Hé, d'où vient?</l>
          <l met="7">Un prologue<note>Note du manuscrit: «<emph>L'Assemblée des acteurs</emph>, prologue ajouté à la pièce des<emph>Trois cousines</emph>».</note>est l'hameçon,</l>
          <l met="5">Paris le poisson.</l>
        </sp>
        <stage>Fin</stage>
      </div>
    </body>
  </text>
</TEI>