  <text>
    <front>
      <prologue>
        <sp who="#lustucru">
          <speaker>Lustucru</speaker>
        </sp>
        <spGrp who="#lustucru">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#confiteor">Mon père, je viens devant vous</title>
            </desc>
          </head>
          <sp who="#lustucru">
            <speaker>Lustucru</speaker>
            <l met="8">Frappons, ne nous lassons jamais,</l>
            <l met="8">Frappons, que rien ne nous arrête!</l>
            <l met="8">La femme malgré ses attraits</l>
            <l met="8">A bien des défauts dans la tête.</l>
            <l met="8">Ne nous lassons jamais, frappons!</l>
            <l met="8">Refondons-la si nous pouvons.</l>
          </sp>
        </spGrp>
        <spGrp who="#lustucru">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#cher_voisin">Que je chéris mon cher voisin</title>
            </desc>
          </head>
          <sp who="#lustucru">
            <speaker>Lustucru</speaker>
            <l met="8">C'est Vulcain, ce pauvre boiteux</l>
            <l met="6">Qui forge le tonnerre.</l>
            <l met="8">L'Amour forge les traits fâcheux</l>
            <l met="6">Qu'il lance sur la terre.</l>
          </sp>
        </spGrp>
        <spGrp>
          <head type="melody" subtype="same_melody">Même air</head>
          <sp who="#lustucru">
            <speaker>Lustucru</speaker>
            <l met="8">Lustucru, ce grand forgeron</l>
            <l met="6">Que partout on réclame,</l>
            <l met="8">Sait par son art sage et profond</l>
            <l met="6">Faire une bonne femme.</l>
          </sp>
        </spGrp>
        <sp who="#pierrot">
          <speaker>Pierrot</speaker>
        </sp>
        <spGrp who="#pierrot">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#peril_agreable">Quand le péril est agréable</title>
            </desc>
          </head>
          <sp who="#pierrot">
            <speaker>Pierrot</speaker>
            <l met="8">Voulez-vous le repos de l'âme</l>
            <l met="8">Et dans vos maison vivre en paix?</l>
            <l met="8">N'ayez ni dettes ni procès,</l>
            <l met="6">Encore moins de femme.</l>
          </sp>
        </spGrp>
        <stage>Lustucru examine le travail des forgerons et présente un écriteau:</stage>
        <spGrp>
          <head type="melody" subtype="same_melody">Même air</head>
          <sp who="#pierrot">
            <speaker>Pierrot</speaker>
            <l met="8">Maris, venez tous prendre place</l>
            <l met="8">Sur les bancs du bon Lustucru!</l>
            <l met="8">Il rend le front le plus tortu</l>
            <l met="5">Lisse comme une glace.</l>
          </sp>
        </spGrp>
        <stage>On entend du bruit et Lustucru présente un écriteau:</stage>
        <spGrp who="#pierrot">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#philis_avare">Réveillez-vous, belle endormie</title>
            </desc>
          </head>
          <sp who="#pierrot">
            <speaker>Pierrot</speaker>
            <l met="8">Quels bruits à  nos désirs contraires!</l>
            <l met="8">Quels tintamarres et quels cris!</l>
            <l met="8">Ô ciel, c'est un tas d'harengères!</l>
            <l met="8">Vraiment, je n'en suis pas surpris.</l>
          </sp>
        </spGrp>
        <stage>Colombine s'adresse à  Lustucru et présente un écriteau:</stage>
        <sp who="#colombine">
          <speaker>Colombine</speaker>
        </sp>
        <spGrp who="#colombine">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#cher_voisin">Que je chéris mon cher voisin</title>
            </desc>
          </head>
          <sp who="#colombine">
            <speaker>Colombine</speaker>
            <l met="8">Crois-tu de nous faire la loi?</l>
            <l met="6">Quelle mouche te pique?</l>
            <l met="8">Si nous tombons toutes sur toi,</l>
            <l met="6">C'est fait de ta boutique.</l>
          </sp>
        </spGrp>
        <sp who="#isabelle">
          <speaker>Isabelle</speaker>
          <stage>à  Lustucru</stage>
        </sp>
        <spGrp who="#isabelle">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#peril_agreable">Quand le péril est agréable</title>
            </desc>
          </head>
          <sp who="#isabelle">
            <speaker>Isabelle</speaker>
            <l met="8">Le traître à  qui le sort me lie</l>
            <l met="8">A fort bien fait de décamper.</l>
            <l met="8">Ah, si j'avais pu l'attraper,</l>
            <l met="6">C'était fait de sa vie!</l>
          </sp>
        </spGrp>
        <stage>Lustucru répond par un écriteau:</stage>
        <sp who="#lustucru">
          <speaker>Lustucru</speaker>
        </sp>
        <spGrp who="#lustucru">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#philis_avare">Réveillez-vous, belle endormie</title>
            </desc>
          </head>
          <sp who="#lustucru">
            <speaker>Lustucru</speaker>
            <l met="8">Honteux de vous voir la culotte,</l>
            <l met="8">Votre époux a recours à  moi.</l>
            <l met="8">Il veut, Madame, qu'on vous l'ôte;</l>
            <l met="8">Il n'a pas grand tort, par ma foi.</l>
          </sp>
        </spGrp>
        <sp who="#colombine">
          <speaker>Colombine</speaker>
          <stage>à  Lustucru</stage>
        </sp>
        <spGrp>
          <head type="melody" subtype="same_melody">Même air</head>
          <sp who="#colombine">
            <speaker>Colombine</speaker>
            <l met="8">Aujourd'hui, la plupart des hommes</l>
            <l met="8">Sont devenus efféminés</l>
            <l met="8">Et nous, femmes tant que nous sommes,</l>
            <l met="8">Nous les menons tous par le nez.</l>
          </sp>
        </spGrp>
        <sp who="#lustucru">
          <speaker>Lustucru</speaker>
          <stage>à  Colombine</stage>
        </sp>
        <spGrp who="#lustucru">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#vous_m_entendez_bien_2">Vous m'entendez bien</title>
            </desc>
          </head>
          <sp who="#lustucru">
            <speaker>Lustucru</speaker>
            <l met="8">Ce discours si sage et si doux,</l>
            <l met="8">Cet air à  faire des jaloux,</l>
            <l met="6">Ce maintien, cette gorge,</l>
            <l met="2">Ces yeux</l>
            <l met="6">Méritent qu'on vous forge</l>
            <l met="5">La tête un peu mieux.</l>
          </sp>
        </spGrp>
        <sp who="#colombine">
          <speaker>Colombine</speaker>
          <stage>à  Isabelle</stage>
        </sp>
        <spGrp who="#colombine">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title"/>
          </head>
          <sp who="#colombine">
            <speaker>Colombine</speaker>
            <l met="6">Ce magot nous outrage,</l>
            <l met="6">Arrachons-lui les yeux!</l>
            <l met="8">Qu'on reconnaisse à  notre rage</l>
            <l met="8">Que les femmes sont dans ces lieux.</l>
          </sp>
          <sp who="#colombine">
            <speaker>Colombine</speaker>
            <l met="8">Maris, que  vous êtes à  plaindre,</l>
            <l met="7">Vos cris seront superflus!</l>
            <l met="8">Vos femmes vont se faire craindre.</l>
            <l met="9">Bon bon bon, Lustucru ne vit plus.</l>
          </sp>
        </spGrp>
        <stage>Colombine et Isabele font mourir Lustucru et présentent un écriteau:</stage>
        <stage>Fin du prologue</stage>
        <sp who="#colombine">
          <speaker>Colombine</speaker>
        </sp>
        <spGrp who="#colombine">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#cher_voisin">Que je chéris mon cher voisin</title>
            </desc>
          </head>
          <sp who="#colombine">
            <speaker>Colombine</speaker>
            <l met="8">Garderai-je éternellement</l>
            <l met="6">Mon innocence en gage?</l>
            <l met="8">Ah, c'est un fardeau bien pesant</l>
            <l met="6">Quand on est à  mon âge.</l>
          </sp>
        </spGrp>
        <spGrp who="#colombine">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#peril_agreable">Quand le péril est agréable</title>
            </desc>
          </head>
          <sp who="#colombine">
            <speaker>Colombine</speaker>
            <l met="8">Quand on est déjà  grandelette,</l>
            <l met="8">Le cœur par amour attaché,</l>
            <l met="8">Hélas, quelle fatalité</l>
            <l met="6">D'être toujours seulette!</l>
          </sp>
        </spGrp>
        <spGrp who="#colombine">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#philis_avare">Réveillez-vous, belle endormie</title>
            </desc>
          </head>
          <sp who="#colombine">
            <speaker>Colombine</speaker>
            <l met="8">Que pour mes amoureuses flammes,</l>
            <l met="8">Le sérail est de mauvais goà»t!</l>
            <l met="8">On est ici plus de cent femmes,</l>
            <l met="8">Et nous n'avons qu'un homme en tout.</l>
          </sp>
        </spGrp>
        <spGrp>
          <head type="melody" subtype="same_melody">Même air</head>
          <sp who="#colombine">
            <speaker>Colombine</speaker>
            <l met="8">Pour brûler d'une ardeur nouvelle</l>
            <l met="8">Le Grand Turc vient ici nous voir.</l>
            <l met="8">Amour, fais qu'il me trouve belle,</l>
            <l met="8">Et qu'il me jette le mouchoir!</l>
          </sp>
        </spGrp>
        <sp who="#isabelle">
          <speaker>Isabelle</speaker>
          <stage>au Grand Turc</stage>
        </sp>
        <spGrp>
          <head type="melody" subtype="same_melody">Même air</head>
          <sp who="#isabelle">
            <speaker>Isabelle</speaker>
            <l met="8">Les cris d'une amante alarmée,</l>
            <l met="8">Ingrat, seront-ils superflus?</l>
            <l met="8">Ah, pourquoi m'avez-vous aimée</l>
            <l met="8">Ou pourquoi ne m'aimez-vous plus?</l>
          </sp>
        </spGrp>
        <sp who="#turc">
          <speaker>Le grand turc</speaker>
          <l met="8">L'amour est un oiseau volage</l>
          <l met="8">Qu'on ne peut guère retenir.</l>
          <l met="8">Mais quoiqu'il sorte de sa cage,</l>
          <l met="8">Il peut parfois y revenir.</l>
        </sp>
        <sp who="#isabelle">
          <speaker>Isabelle</speaker>
          <stage>au Grand Turc</stage>
        </sp>
        <spGrp who="#isabelle">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#trembleurs">Les Trembleurs</title>
            </desc>
          </head>
          <sp who="#isabelle">
            <speaker>Isabelle</speaker>
            <l met="7">Ah, que votre âme est cruelle</l>
            <l met="7">De trahir un cœur fidèle!</l>
            <l met="7">Ne suis-je plus assez belle</l>
            <l met="7">Pour vous plaire encore un peu?</l>
            <l met="7">Depuis longtemps pour mes charmes</l>
            <l met="7">Vous ne prenez plus les armes,</l>
            <l met="7">Et si j'en crois mes alarmes,</l>
            <l met="7">Vous brûlez d'un autre feu.</l>
          </sp>
        </spGrp>
        <sp who="#turc">
          <speaker>Le grand turc</speaker>
        </sp>
        <spGrp who="#turc">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#confiteor">Mon père, je viens devant vous</title>
            </desc>
          </head>
          <sp who="#turc">
            <speaker>Le grand turc</speaker>
            <l met="8">Vous méritez un sort plus doux.</l>
            <l met="8">À regret, je suis infidèle.</l>
            <l met="8">Je reviendrai bientôt à  vous,</l>
            <l met="8">Si je n'en trouve de plus belle.</l>
            <l met="8">Mais ma foi, ne m'attendez pas,</l>
            <l met="8">Si je rencontre plus d'appas.</l>
          </sp>
        </spGrp>
        <sp who="#turc">
          <speaker>Le grand turc</speaker>
          <stage>apercevant Colombine</stage>
        </sp>
        <spGrp who="#turc">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#folia">Folies d'Espagne</title>
            </desc>
          </head>
          <sp who="#turc">
            <speaker>Le grand turc</speaker>
            <l met="10">Cette beauté qu'ici mon ordre amène</l>
            <l met="10">Va par ses soins répondre à  mes désirs.</l>
            <l met="10">Portez ailleurs vos cris et votre peine,</l>
            <l met="10">Et gardez-vous de troubler mes plaisirs!</l>
          </sp>
        </spGrp>
        <sp who="#isabelle">
          <speaker>Isabelle</speaker>
          <stage>au Grand Turc</stage>
        </sp>
        <spGrp who="#isabelle">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title"/>
          </head>
          <sp who="#isabelle">
            <speaker>Isabelle</speaker>
            <l met="9">Quoi, Seigneur, vous le ne cachez pas?</l>
            <l met="9">Vous allez chercher d'autres appas.</l>
            <l met="9">De fureur déjà  mon cœur palpite.</l>
            <l met="10">Je ne suis plus maîtresse de mes sens.</l>
            <l met="9">Si vous ne revenez au plus vite,</l>
            <l met="10">Je c[r]èverai des maux que je ressens.</l>
          </sp>
        </spGrp>
        <sp who="#choeur">
          <speaker>Le choeur</speaker>
        </sp>
        <spGrp who="#choeur">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#folia">Folies d'Espagne</title>
            </desc>
          </head>
          <sp who="#choeur">
            <speaker>Le choeur</speaker>
            <l met="10">Maris jaloux, oubliez vos alarmes!</l>
            <l met="10">Imitez tous le Grand Turc aujourd'hui.</l>
            <l met="10">Et comme il a le croissant dans ses armes,</l>
            <l met="10">Sans murmurer portez-le comme lui.</l>
          </sp>
        </spGrp>
        <sp who="#turc">
          <speaker>Le grand turc</speaker>
          <stage>à  Colombine</stage>
        </sp>
        <spGrp who="#turc">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#philis_avare">Réveillez-vous, belle endormie</title>
            </desc>
          </head>
          <sp who="#turc">
            <speaker>Le grand turc</speaker>
            <l met="8">Vous brillez seule en ce refuge,</l>
            <l met="8">Ne retardez pas mon dessein!</l>
            <l met="9">Si je ne vous croque et ne vous gruge</l>
            <l met="8">Mon amour va mourir de faim.</l>
          </sp>
        </spGrp>
        <stage>Colombine fait des minauderies au Grand Turc et présente un écriteau:</stage>
        <spGrp who="#turc">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#tout_cela_est_indifferent">Le Prévôt des marchands</title>
            </desc>
          </head>
          <sp who="#turc">
            <speaker>Le grand turc</speaker>
            <l met="8">Seigneur, sur moi l'amour a fait</l>
            <l met="8">Comme sur vous le même effet.</l>
            <l met="8">Déjà  mon âme vous dévore.</l>
            <l met="8">Pourquoi teniez-vous renfermé</l>
            <l met="8">Ce que tout l'univers adore</l>
            <l met="8">Et dont mon cœur est si charmé?</l>
          </sp>
        </spGrp>
        <stage>Isabelle entre en fureur et présente un écriteau:</stage>
        <spGrp who="#turc">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title"/>
          </head>
          <sp who="#turc">
            <speaker>Le grand turc</speaker>
            <l met="5">Malheureux moment</l>
            <l met="5">Qui fait mon tourment!</l>
            <l met="8">Allons avec cet instrument</l>
            <l met="8">Embrocher l'amante et l'amant!</l>
            <l met="6">Auprès de ses appas,</l>
            <l met="6">Je vois bien qu'il n'a pas</l>
            <l met="5">Perdu la parole.</l>
            <l met="8">Vertuchoux, comme il la cajole,</l>
            <l met="8">Au lieu qu'auprès de mon jabot,</l>
            <l met="8">Il ronfle et dort comme un sabot!</l>
          </sp>
        </spGrp>
        <sp who="#arlequin">
          <speaker>Arlequin</speaker>
        </sp>
        <spGrp who="#arlequin">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#peril_agreable">Quand le péril est agréable</title>
            </desc>
          </head>
          <sp who="#arlequin">
            <speaker>Arlequin</speaker>
            <l met="8">Je crois qu'elle est ensorcelée,</l>
            <l met="8">Vite, qu'on l'ôte de mes yeux!</l>
            <l met="8">Pour calmer ses feux furieux,</l>
            <l met="6">Qu'elle soit empalée!</l>
          </sp>
        </spGrp>
        <stage>Colombine demande grâce pour Isabelle et présente un écriteau:</stage>
        <spGrp who="#arlequin">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#cher_voisin">Que je chéris mon cher voisin</title>
            </desc>
          </head>
          <sp who="#arlequin">
            <speaker>Arlequin</speaker>
            <l met="8">Seigneur, au nom de notre amour,</l>
            <l met="6">Ne vengez cet outrage</l>
            <l met="8">Qu'en me redoublant chaque jour</l>
            <l met="6">Votre amoureux hommage.</l>
          </sp>
        </spGrp>
        <stage>Arlequin révoque son arrête et présente un écriteau:</stage>
        <spGrp>
          <head type="melody" subtype="same_melody">Même air</head>
          <sp who="#arlequin">
            <speaker>Arlequin</speaker>
            <l met="8">Allons, que tout signale ici</l>
            <l met="6">Nos ardeurs mutuelles,</l>
            <l met="8">Et que dans un moment aussi</l>
            <l met="6">On souffle les chandelles!</l>
          </sp>
        </spGrp>
        <stage>Pierrot, voulant secourir Arlequin, demande du secours par un écriteau:</stage>
        <spGrp who="#arlequin">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#ne_m_entendez_vous_pas">Ne m'entendez-vous pas?</title>
            </desc>
          </head>
          <sp who="#arlequin">
            <speaker>Arlequin</speaker>
            <l met="6">Au secours, au secours!</l>
            <l met="6">Ô fortune ennemie!</l>
            <l met="6">Arlequin perd la vie</l>
            <l met="6">Au plus beau de ses jours.</l>
            <l met="6">Au secours, au secours!</l>
          </sp>
        </spGrp>
        <stage>Colombine arrive au secours et présente un écriteau:</stage>
        <spGrp who="#arlequin">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#philis_avare">Réveillez-vous, belle endormie</title>
            </desc>
          </head>
          <sp who="#arlequin">
            <speaker>Arlequin</speaker>
            <l met="8">Quel objet! J'en suis attendrie,</l>
            <l met="8">En vain j'appelle ma fierté.</l>
            <l met="8">Ah, faut-il lui rendre la vie</l>
            <l met="8">Aux dépends de ma liberté?</l>
          </sp>
        </spGrp>
        <spGrp who="#arlequin">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#dondaine_dondaine">Ah, qu'il est beau, l'oiseau qu'Amour m'amène</title>
            </desc>
          </head>
          <sp who="#arlequin">
            <speaker>Arlequin</speaker>
            <l met="8">Qu'il est joli le jouveanceau,</l>
            <l met="8">C'est pour mon cœur du fruit nouveau.</l>
            <l met="5">Je l'aime, je l'aime!</l>
            <l met="6">Ah, que son teint est beau,</l>
            <l met="4">C'est l'Amour même!</l>
          </sp>
        </spGrp>
        <sp who="#pierrot">
          <speaker>Pierrot</speaker>
        </sp>
        <spGrp who="#pierrot">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#peril_agreable">Quand le péril est agréable</title>
            </desc>
          </head>
          <sp who="#pierrot">
            <speaker>Pierrot</speaker>
            <l met="8">Cette eau de la reine d'Hongrie</l>
            <l met="8">N'est pas bonne pour un mari.</l>
            <l met="8">Donnez-lui plutôt de bon vin,</l>
            <l met="6">Ou bien de l'eau de vie.</l>
          </sp>
        </spGrp>
        <stage>Colombine présente du ratafia à  Arlequin, qui en boit et présente un écriteau:</stage>
        <sp who="#arlequin">
          <speaker>Arlequin</speaker>
        </sp>
        <spGrp who="#arlequin">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#vous_m_entendez_bien_2">Vous m'entendez bien</title>
            </desc>
          </head>
          <sp who="#arlequin">
            <speaker>Arlequin</speaker>
            <l met="8">Vous m'avez sauvé du trépas</l>
            <l met="8">Mais cela ne me suffit pas.</l>
            <l met="6">Cher objet que j'adore,</l>
            <l met="2">Hélas!</l>
            <l met="6">Je voudrais bien encore,</l>
            <l met="5">N'entendez-vous pas?</l>
          </sp>
        </spGrp>
        <stage>Scaramouche, en habit de femme, les surprend et présente un écriteau:</stage>
        <sp who="#scaramouche">
          <speaker>Scaramouche</speaker>
          <stage>en Calypso, à  Colombine</stage>
        </sp>
        <spGrp who="#scaramouche">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#philis_avare">Réveillez-vous, belle endormie</title>
            </desc>
          </head>
          <sp who="#scaramouche">
            <speaker>Scaramouche</speaker>
            <l met="8">Je ne sais pas si c'est un somme</l>
            <l met="8">Ou si mon réveil est parfait.</l>
            <l met="8">Quoi! Seule ici près d'un jeune homme!</l>
            <l met="7">Qu'y faisiez-vous s'il vous plaît?</l>
          </sp>
        </spGrp>
        <stage>Colombine, scandalisée, présente un écriteau:</stage>
        <sp who="#colombine">
          <speaker>Colombine</speaker>
        </sp>
        <spGrp>
          <head type="melody" subtype="same_melody">Même air</head>
          <sp who="#colombine">
            <speaker>Colombine</speaker>
            <l met="8">Ce cavalier a fait naufrage</l>
            <l met="8">Et l'eau l'avait presque étouffé.</l>
            <l met="8">Il serait mort de froid je gage,</l>
            <l met="8">Si je ne l'avais réchauffé.</l>
          </sp>
        </spGrp>
        <sp who="#calscar">
          <speaker>Calypso ou scaramouche</speaker>
        </sp>
        <spGrp who="#calscar">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#cher_voisin">Que je chéris mon cher voisin</title>
            </desc>
          </head>
          <sp who="#calscar">
            <speaker>Calypso ou scaramouche</speaker>
            <l met="8">Avez-vous demandé le nom</l>
            <l met="6">De ce charmant corsaire?</l>
            <l met="8">Oh, je gagerais bien que non:</l>
            <l met="6">Vous aviez autre affaire!</l>
          </sp>
        </spGrp>
        <stage>Arlequin, faisant le beau, présente un écriteau</stage>
        <sp who="#arlequin">
          <speaker>Arlequin</speaker>
          <stage>à  Calypso</stage>
        </sp>
        <spGrp>
          <head type="melody" subtype="same_melody">Même air</head>
          <sp who="#arlequin">
            <speaker>Arlequin</speaker>
            <l met="8">À ce grand air, à  ces appas,</l>
            <l met="6">Sans fard, sans artifice,</l>
            <l met="8">Madame, ne voyez-vous pas</l>
            <l met="6">Que je suis fils d'Ulysse?</l>
          </sp>
        </spGrp>
        <stage>Calypso entre en fureur au nom d'Ulysse et présente un écriteau:</stage>
        <sp who="#calscar">
          <speaker>Calypso ou scaramouche</speaker>
        </sp>
        <spGrp who="#calscar">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#tout_cela_est_indifferent">Le Prévôt des marchands</title>
            </desc>
          </head>
          <sp who="#calscar">
            <speaker>Calypso ou scaramouche</speaker>
            <l met="8">Le fils d'Ulysse, justes dieux!</l>
            <l met="8">Ah, tu périras, malheureux!</l>
            <l met="8">Qu'on garrotte le téméraire!</l>
            <l met="8">Mes vœux sont enfin satisfaits.</l>
            <l met="8">Le fils payera pour le père</l>
            <l met="8">Tous les outrages qu'il m'a faits.</l>
          </sp>
        </spGrp>
        <stage>Arlequin pleure et le Docteur le blâme de sa faiblesse et présente un écriteau:</stage>
        <sp who="#docteur">
          <speaker>Le docteur</speaker>
        </sp>
        <spGrp who="#docteur">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#philis_avare">Réveillez-vous, belle endormie</title>
            </desc>
          </head>
          <sp who="#docteur">
            <speaker>Le docteur</speaker>
            <l met="8">Ah, vous trahissez votre gloire</l>
            <l met="8">Par les pleurs que vous répandez.</l>
            <l met="8">Avez-vous perdu la mémoire</l>
            <l met="8">Du beau sang dont vous descendez?</l>
          </sp>
        </spGrp>
        <stage>Arlequin, embrassant l'autel, présente un écriteau:</stage>
        <spGrp>
          <head type="melody" subtype="same_melody">Même air</head>
          <sp who="#docteur">
            <speaker>Le docteur</speaker>
            <l met="8">Cher auteur de ma chère vie,</l>
            <l met="8">Hélas, je vais mourir pour toi.</l>
            <l met="8">Je n'en ai pas trop grande envie,</l>
            <l met="8">Et ce sera bien malgré moi.</l>
          </sp>
        </spGrp>
        <spGrp who="#docteur">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#folia">Folies d'Espagne</title>
            </desc>
          </head>
          <sp who="#docteur">
            <speaker>Le docteur</speaker>
            <l met="10">Frappez, frappez, que rien ne vous arrête,</l>
            <l met="10">Mais prenez garde à  bien porter vos coups,</l>
            <l met="10">Et n'allez pas me donner sur la tête:</l>
            <l met="10">Le sang pourrait en rejaillir sur vous.</l>
          </sp>
        </spGrp>
        <stage>Calypso, arrêtant le bras du Grand Sacrificateur, présente un écriteau:</stage>
        <sp who="#calscar">
          <speaker>Calypso ou scaramouche</speaker>
        </sp>
        <spGrp who="#calscar">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#tout_cela_est_indifferent">Le Prévôt des marchands</title>
            </desc>
          </head>
          <sp who="#calscar">
            <speaker>Calypso ou scaramouche</speaker>
            <l met="8">Arrête, arrête, vieux penard,</l>
            <l met="8">Cruel, rengaine ton poignard!</l>
            <l met="8">Quelle est donc ta fureur extrême?</l>
            <l met="8">Quoi! poignarder un innocent?</l>
            <l met="8">Et le  crime en sera moins grand?</l>
          </sp>
        </spGrp>
        <stage>Adraste, mécontent du soin que Calypso prend d'Arlequin, présente un écriteau:</stage>
        <sp who="#adraste">
          <speaker>Adraste</speaker>
        </sp>
        <spGrp who="#adraste">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#confiteor">Mon père, je viens devant vous</title>
            </desc>
          </head>
          <sp who="#adraste">
            <speaker>Adraste</speaker>
            <l met="8">Vous êtes reine, je suis roi;</l>
            <l met="8">Mon royaume vaut bien le vôtre.</l>
            <l met="8">Mais puisqu'on se moque de moi</l>
            <l met="8">Et qu'on me quitte pour un autre,</l>
            <l met="8">Je m'en retourne dans ma cour,</l>
            <l met="8">Et je vous donne le bonjour.</l>
          </sp>
        </spGrp>
        <stage>En se retirant, il un autre écriteau:</stage>
        <spGrp who="#adraste">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#vous_m_entendez_bien_2">Vous m'entendez bien</title>
            </desc>
          </head>
          <sp who="#adraste">
            <speaker>Adraste</speaker>
            <l met="8">Quel que soit pour lui votre amour,</l>
            <l met="8">Télémaque perdra le jour.</l>
            <l met="6">Et vous pouvez bien croire</l>
            <l met="2">Du moins</l>
            <l met="6">Qu'il mourra de la Foire</l>
            <l met="5">Malgré tous vos soins.</l>
          </sp>
        </spGrp>
        <sp who="#arlequin">
          <speaker>Arlequin</speaker>
          <stage>à  Calypso</stage>
        </sp>
        <spGrp who="#arlequin">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#philis_avare">Réveillez-vous, belle endormie</title>
            </desc>
          </head>
          <sp who="#arlequin">
            <speaker>Arlequin</speaker>
            <l met="8">N'ayez pas tant l'âme chagrine,</l>
            <l met="8">Calmez vos transports furieux!</l>
            <l met="8">Vous serez, après Colombine,</l>
            <l met="8">Tout ce que j'aimerai le mieux.</l>
          </sp>
        </spGrp>
        <sp who="#colombine">
          <speaker>Colombine</speaker>
        </sp>
        <spGrp who="#colombine">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#malheureux_oui">Quand on a prononcé ce malheureux oui</title>
            </desc>
          </head>
          <sp who="#colombine">
            <speaker>Colombine</speaker>
            <l met="6">Ne vous obstinez pas</l>
            <l met="6">À faire le sévère.</l>
            <l met="6">La reine a plus d'appas</l>
            <l met="6">Qu'il n'en faut pour vous plaire.</l>
            <l met="12">Chez elle tous les jours on fait de grands repas,</l>
            <l met="12">Et vous n'auriez chez moi que le reste des plats.</l>
          </sp>
        </spGrp>
        <stage>Calypso s'irrite et présente un écriteau:</stage>
        <spGrp who="#colombine">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#tout_cela_est_indifferent">Le Prévôt des marchands</title>
            </desc>
          </head>
          <sp who="#colombine">
            <speaker>Colombine</speaker>
            <l met="8">Puisque tu ne veux pas de moi,</l>
            <l met="8">Je ne veux plus aussi de toi.</l>
            <l met="8">Mais dans le sang de ton amante</l>
            <l met="8">Je prétends noyer mon amour</l>
            <l met="8">Qu'on saisisse cette insolente</l>
            <l met="8">Et qu'on la mène dans la tour!</l>
          </sp>
        </spGrp>
        <stage>Arlequin, voyant venir du secours, présente un écriteau:</stage>
        <spGrp who="#colombine">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#philis_avare">Réveillez-vous, belle endormie</title>
            </desc>
          </head>
          <sp who="#colombine">
            <speaker>Colombine</speaker>
            <l met="8">Fort à  propos sur ce rivage,</l>
            <l met="8">Le ciel vous a fait arriver.</l>
            <l met="8">On a mis ma maîtresse en cage,</l>
            <l met="8">Et je voudrais bien l'enlever.</l>
          </sp>
        </spGrp>
        <stage>Calypso invoque les démons et présente un écriteau:</stage>
        <sp who="#calscar">
          <speaker>Calypso ou scaramouche</speaker>
        </sp>
        <spGrp who="#calscar">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#tout_cela_est_indifferent">Le Prévôt des marchands</title>
            </desc>
          </head>
          <sp who="#calscar">
            <speaker>Calypso ou scaramouche</speaker>
            <l met="8">Plus de pitié, plus de retour!</l>
            <l met="8">Sors de mon cœur indigne amour.</l>
            <l met="7">Et toi, troupe diabolique</l>
            <l met="8">Si tu ne veux me voir mourir,</l>
            <l met="8">De la rage ou de la colique,</l>
            <l met="8">Hâte-toi de me secourir!</l>
          </sp>
        </spGrp>
        <stage>Le Docteur vient défendre Arlequin et présente un écriteau:</stage>
        <spGrp who="#calscar">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#cher_voisin">Que je chéris mon cher voisin</title>
            </desc>
          </head>
          <sp who="#calscar">
            <speaker>Calypso ou scaramouche</speaker>
            <l met="8">Je saurai bien parer les coups</l>
            <l met="6">Que sa main vous réserve,</l>
            <l met="8">Calypso, me connaissez-vous?</l>
            <l met="6">Je m'appelle Minerve.</l>
          </sp>
        </spGrp>
        <spGrp>
          <head type="melody" subtype="same_melody">Même air</head>
          <sp who="#calscar">
            <speaker>Calypso ou scaramouche</speaker>
            <l met="8">Deviens, par mon commandement</l>
            <l met="6">Devenez immobiles!</l>
            <l met="8">Je vous rendrai le mouvement</l>
            <l met="6">Quand nous aurons fait Gilles.</l>
          </sp>
        </spGrp>
        <sp who="#calscar">
          <speaker>Calypso ou scaramouche</speaker>
        </sp>
        <spGrp who="#calscar">
          <head type="melody" subtype="restored_melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#tout_cela_est_indifferent">Le Prévôt des marchands</title>
            </desc>
          </head>
          <sp who="#calscar">
            <speaker>Calypso ou scaramouche</speaker>
            <l met="8">Ô toi de qui je tiens le jour,</l>
            <l met="8">Venge-moi de ce vilain tour!</l>
            <l met="8">Renverse le céleste empire!</l>
            <l met="8">Punis tous ces dieux déchaînés,</l>
            <l met="8">Et si tu veux me faire rire,</l>
            <l met="7">Fais qu'il se cassent le nez!</l>
          </sp>
        </spGrp>
        <stage>Fin</stage>
      </prologue>
    </front>
    <body>
      <div type="act">
        <head>ACTE 1</head>
      </div>
      <div type="act">
        <head>ACTE 2</head>
      </div>
    </body>
