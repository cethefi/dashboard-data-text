      <prologue>
        <stage type="location">Le théâtre représente la même décoration de l'opéra de Psyché, quand l'Amour s'endort sous une alcôve.</stage>
      </prologue>
      <pb n="73" facs="https:/gallica.bnf.fr/ark:/12148/btv1b90611278/f227.item"/>
    </front>
    <body>
      <div type="scene">
        <head>SCENE 1</head>
        <stage type="characters">L'Amour et Vénus</stage>
        <sp who="#lamour">
          <speaker>L'amour</speaker>
        </sp>
        <spGrp who="#lamour">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#barbari">La faridondenne</title>
            </desc>
          </head>
          <sp who="#lamour">
            <speaker>L'amour</speaker>
            <l met="8">Je me transforme en grand garçon,</l>
            <l met="6">Ma Psyché va se rendre,</l>
            <l met="8">Il faut de la barbe au menton,</l>
            <l met="6">Mesdames, pour vous prendre,</l>
            <l met="8">L'on méconnaîtra Cupidon,</l>
            <l met="11">La faridondenne, la faridondon.</l>
          </sp>
        </spGrp>
        <sp who="#venus">
          <speaker>Vénus</speaker>
          <l met="11">Le beau brunet, qu'il est joli, biribi,</l>
          <l met="11">À la façon de Barbari, mon ami.</l>
        </sp>
        <sp who="#venus">
          <speaker>Vénus</speaker>
        </sp>
        <spGrp who="#venus">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#beaux_yeux_nicole">Tes beaux yeux, ma Nicole</title>
            </desc>
          </head>
          <sp who="#venus">
            <speaker>Vénus</speaker>
            <l met="6">Voyez sous quel beau masque</l>
            <l met="6">Cupidon s'est caché!</l>
            <l met="6">Tu crois, marmot fantasque,</l>
            <l met="6">Épouser ta Psyché?</l>
            <l met="6">Je verrais à Cythère</l>
            <l met="6">De petits margajats</l>
            <l met="6">M'appeler leur grand-mère!</l>
          </sp>
        </spGrp>
        <sp who="#lamour">
          <speaker>L'amour</speaker>
          <l met="6">Fi, cela ne sied pas.</l>
        </sp>
        <sp who="#venus">
          <speaker>Vénus</speaker>
        </sp>
        <spGrp who="#venus">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#mere_mariez_moi">Ma mère, mariez-moi</title>
            </desc>
          </head>
          <sp who="#venus">
            <speaker>Vénus</speaker>
            <l met="7">Voyez le plaisant époux,</l>
            <l met="7">Quoi! Je vous marierais vous!</l>
          </sp>
        </spGrp>
        <sp who="#lamour">
          <speaker>L'amour</speaker>
          <l met="7">Vous l'étiez à quatorze ans,</l>
          <l met="10">Vous me l'avez dit, souvenez-vous en.</l>
        </sp>
        <sp who="#venus">
          <speaker>Vénus</speaker>
          <l met="7">Je n'aime pas les maris.</l>
        </sp>
        <sp who="#lamour">
          <speaker>L'amour</speaker>
          <l met="7">Mon papa l'a bien appris.</l>
        </sp>
        <sp who="#venus">
          <speaker>Vénus</speaker>
        </sp>
        <spGrp who="#venus">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#aimant_colette">Tu croyais, en aimant Colette</title>
            </desc>
          </head>
          <sp who="#venus">
            <speaker>Vénus</speaker>
            <l met="8">Cherche pour femme une autre fille,</l>
            <l met="8">Ha, tu me fais frémir d'effroi.</l>
            <l met="8">Quoi? Je verrais dans ma famille</l>
            <l met="8">Une bru plus belle que moi?</l>
          </sp>
        </spGrp>
        <sp who="#lamour">
          <speaker>L'amour</speaker>
        </sp>
        <spGrp who="#lamour">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#philis_avare">Réveillez-vous, belle endormie</title>
            </desc>
          </head>
          <sp who="#lamour">
            <speaker>L'amour</speaker>
            <l met="8">Songez à ce que je puis faire.</l>
          </sp>
        </spGrp>
        <sp who="#venus">
          <speaker>Vénus</speaker>
          <l met="8">Non, je ne veux plus de tes soins.</l>
        </sp>
        <pb n="74" facs="https:/gallica.bnf.fr/ark:/12148/btv1b90611278/f228.item"/>
        <sp who="#lamour">
          <speaker>L'amour</speaker>
          <l met="8">Je vous suis assez nécessaire,</l>
          <l met="8">Maman, vous savez vos besoins.</l>
        </sp>
        <sp who="#venus">
          <speaker>Vénus</speaker>
        </sp>
        <spGrp who="#venus">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#pour_vous_monsieur_le_sauvage">Pour vous, Monsieur le Sauvage</title>
            </desc>
          </head>
          <sp who="#venus">
            <speaker>Vénus</speaker>
            <l met="7">C'est ainsi qu'un fils me traite?</l>
            <l met="7">Ta maîtresse en pâtira.</l>
            <l met="7">Je la rendrai si coquette</l>
          </sp>
        </spGrp>
        <sp who="#lamour">
          <speaker>L'amour</speaker>
          <l met="7">Qu'elle vous ressemblera.</l>
        </sp>
        <sp who="#venus">
          <speaker>Vénus</speaker>
          <l met="7">Tremble, ingrat, pour ta fillette!</l>
        </sp>
        <sp who="#lamour">
          <speaker>L'amour</speaker>
          <l met="7">Tremblez pour votre toilette!</l>
        </sp>
        <sp who="#venus">
          <speaker>Vénus</speaker>
          <l met="7">Je la peindrai de safran.</l>
        </sp>
        <sp who="#lamour">
          <speaker>L'amour</speaker>
          <l met="7">Je vous enverrai mon blanc.</l>
        </sp>
        <stage>L'Amour rentre dans son alcôve et se couche.</stage>
        <sp who="#venus">
          <speaker>Vénus</speaker>
        </sp>
        <spGrp who="#venus">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#tout_cela_est_indifferent">Tout cela m'est indifférent</title>
            </desc>
          </head>
          <sp who="#venus">
            <speaker>Vénus</speaker>
            <l met="8">Or, voilà Cupidon couché,</l>
            <l met="8">Tâchons d'attraper sa Psyché,</l>
            <l met="8">Et que ma haine ingénieuse...</l>
            <l met="8">Je la vois, jouons-lui d'un tour,</l>
            <l met="8">Toute femelle est curieuse</l>
            <l met="8">Surtout quand elle a de l'amour.</l>
          </sp>
        </spGrp>
        <sp who="#psyche">
          <speaker>Psyché</speaker>
        </sp>
        <spGrp>
          <head type="melody" subtype="same_melody">Même air</head>
          <sp who="#psyche">
            <speaker>Psyché</speaker>
            <l met="8">Ah! Quand verrai-je mon amant?</l>
          </sp>
        </spGrp>
        <sp who="#venus">
          <speaker>Vénus</speaker>
          <stage>une lanterne à la main</stage>
          <l met="8">Vous le pouvez en ce moment.</l>
          <l met="8">Tenez, prenez cette lanterne.</l>
        </sp>
        <sp who="#psyche">
          <speaker>Psyché</speaker>
          <l met="8">Je le perdrai si je le vois.</l>
        </sp>
        <sp who="#venus">
          <speaker>Vénus</speaker>
          <l met="8">Quiconque vous le dit vous berne,</l>
          <l met="8">Tirez les rideaux, croyez-moi.</l>
        </sp>
        <sp who="#psyche">
          <speaker>Psyché</speaker>
        </sp>
        <spGrp who="#psyche">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#pendant_une_absence_legere">Pendant une absence légère</title>
            </desc>
          </head>
          <sp who="#psyche">
            <speaker>Psyché</speaker>
            <l met="8">Mais Vénus...</l>
          </sp>
        </spGrp>
        <sp who="#venus">
          <speaker>Vénus</speaker>
          <l met="8">C'est une friponne.</l>
        </sp>
        <sp who="#psyche">
          <speaker>Psyché</speaker>
          <l met="8">Je vous en crois plus que personne.</l>
        </sp>
        <sp who="#venus">
          <speaker>Vénus</speaker>
          <l met="8">Sur ce lit, dans ces doux instants,</l>
          <l met="8">Surprenez l'objet de vos flammes,</l>
          <l met="8">Il ne dormirait pas longtemps,</l>
          <l met="8">Si le cas touchait bien des dames.</l>
        </sp>
        <pb n="75" facs="https:/gallica.bnf.fr/ark:/12148/btv1b90611278/f229.item"/>
        <sp who="#psyche">
          <speaker>Psyché</speaker>
        </sp>
        <spGrp who="#psyche">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#dondaine_dondaine">Ah, qu'il est beau l'oiseau qu'Amour</title>
            </desc>
          </head>
          <sp who="#psyche">
            <speaker>Psyché</speaker>
            <l met="8">Ha, découvrons qui j'ose aimer<stage type="bis">bis</stage>
            </l>
            <l met="8">Sans le voir il sait m'enflammer,</l>
            <l met="5">Je l'aime, je l'aime,</l>
            <l met="8">Dieux, quel amant j'ai su charmer,</l>
            <l met="4">C'est l'Amour même!</l>
          </sp>
        </spGrp>
        <sp who="#lamour">
          <speaker>L'amour</speaker>
        </sp>
        <spGrp who="#lamour">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#adieu_paniers">Adieu paniers, vendanges sont faites</title>
            </desc>
          </head>
          <sp who="#lamour">
            <speaker>L'amour</speaker>
            <l met="8">Tu m'as vu, quittons ces retraites,</l>
            <l met="8">Tu vas tomber dans les enfers.</l>
          </sp>
        </spGrp>
        <sp who="#psyche">
          <speaker>Psyché</speaker>
          <l met="8">Quoi, mon cher amant, je vous perds?</l>
        </sp>
        <sp who="#lamour">
          <speaker>L'amour</speaker>
          <l met="9">Adieu paniers, vendanges sont faites.</l>
        </sp>
      </div>
      <div type="scene">
        <head>SCENE 2</head>
        <stage type="characters">Madame Pernel et Pierrot<stage>en femme</stage>
        </stage>
        <sp who="#mepernel">
          <speaker>Madame pernel</speaker>
        </sp>
        <spGrp who="#mepernel">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air des</desc>
            <desc type="title">
              <title ref="#folia">Folies d'Espagne</title>
            </desc>
          </head>
          <sp who="#mepernel">
            <speaker>Madame pernel</speaker>
            <l met="10">Dans ce palais où tout nous inquiète,</l>
            <l met="10">Les vents nous ont porté avec douceur,</l>
            <l met="10">Un dieu sans doute aime notre cadette!</l>
          </sp>
        </spGrp>
        <sp who="#pierrot">
          <speaker>Pierrot</speaker>
          <l met="10">Ce pourrait bien être un diable, ma sœur.</l>
        </sp>
        <sp who="#mepernel">
          <speaker>Madame pernel</speaker>
        </sp>
        <spGrp who="#mepernel">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#ne_m_entendez_vous_pas">Ne m'entendez-vous pas</title>
            </desc>
          </head>
          <sp who="#mepernel">
            <speaker>Madame pernel</speaker>
            <l met="7">On dit qu'elle ne voit pas</l>
            <l met="6">Cet objet qu'elle enchante.</l>
          </sp>
        </spGrp>
        <sp who="#pierrot">
          <speaker>Pierrot</speaker>
          <l met="6">Tredam un invisible</l>
          <l met="6">Peut faire de bons tours,</l>
          <l met="6">On ne voit pas ses mains.</l>
        </sp>
        <sp who="#mepernel">
          <speaker>Madame pernel</speaker>
        </sp>
        <spGrp who="#mepernel">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#vous_m_entendez_bien_2">Vous m'entendez bien</title>
            </desc>
          </head>
          <sp who="#mepernel">
            <speaker>Madame pernel</speaker>
            <l met="8">Un monstre sur un roc juché</l>
            <l met="8">Devait, dit-on, manger Psyché.</l>
          </sp>
        </spGrp>
        <sp who="#pierrot">
          <speaker>Pierrot</speaker>
          <l met="6">Et zeste la morveuse,</l>
        </sp>
        <sp who="#mepernel">
          <speaker>Madame pernel</speaker>
          <l met="2">Eh bien,</l>
        </sp>
        <sp who="#pierrot">
          <speaker>Pierrot</speaker>
          <l met="12">Dans ce palais peut-être, vous m'entendez bien.</l>
        </sp>
        <sp who="#mepernel">
          <speaker>Madame pernel</speaker>
        </sp>
        <spGrp who="#mepernel">
          <head type="melody" subtype="melody">
            <desc type="prefix">Sur l'air de</desc>
            <desc type="title">
              <title ref="#pendant_une_absence_legere">Pendant une absence légère</title>
            </desc>
          </head>
          <sp who="#mepernel">
            <speaker>Madame pernel</speaker>
            <l met="8">Ma sœur, dans le siècle où nous sommes,</l>
            <l met="8">Qu'est devenu le goût des hommes,</l>
            <l met="8">Qu'ils ont peu de solidité</l>
            <l met="8">D'un enfant leur âme est éprise.</l>
          </sp>
        </spGrp>
        <sp who="#pierrot">
          <speaker>Pierrot</speaker>
          <l met="8">Il n'aime la maturité</l>
          <l met="8">Que dans la poire et la cerise.</l>
        </sp>
        <pb n="76" facs="https:/gallica.bnf.fr/ark:/12148/btv1b90611278/f230.item"/>
